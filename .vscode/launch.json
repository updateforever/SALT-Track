{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python 调试：当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "/root/user-data/envs/wyp_vlt/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYTHONNOUSERSITE": "1",
                "PYTHONHOME": ""
            },
            "justMyCode": false
        },
        {
            "name": "语义调试：最小训练流程",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_training_flow.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "/root/user-data/envs/wyp_vlt/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYTHONNOUSERSITE": "1",
                "PYTHONHOME": ""
            },
            "justMyCode": false
        },
        {
            "name": "ATCTrack 训练：语义版全量训练",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/lib/train/run_training.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "/root/user-data/envs/wyp_vlt/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYTHONNOUSERSITE": "1",
                "PYTHONHOME": "",
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--script", "atctrack",
                "--config", "atctrack_base_semantic",
                "--save_dir", "${workspaceFolder}/output",
                "--use_lmdb", "0",
                "--seed", "42"
            ],
            "justMyCode": false
        },
        {
            "name": "ATCTrack 训练：语义版 LoRA 微调",
